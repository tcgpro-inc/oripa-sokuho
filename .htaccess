RewriteEngine On

# CLIスクリプトへのWebアクセスをブロック
RewriteRule ^bin/ - [F,L]

# HTTPS強制
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# www なしに統一
RewriteCond %{HTTP_HOST} ^www\.oripanews\.com$ [NC]
RewriteRule ^(.*)$ https://oripanews.com/$1 [R=301,L]

# sitemap.xml → sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# 実在するファイル・ディレクトリはそのまま
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# /article/slug/ → article.php?slug=xxx
RewriteRule ^article/([a-zA-Z0-9_-]+)/?$ article.php?slug=$1 [L,QSA]

# /campaign/ → campaign.php
RewriteRule ^campaign/?$ campaign.php [L,QSA]
RewriteRule ^campaign/([a-z]+)/?$ campaign.php?cat=$1 [L,QSA]

# /comment/post → comment-post.php
RewriteRule ^comment/post/?$ comment-post.php [L,QSA]

# カスタム404
ErrorDocument 404 /404.php

# ━━━━━━━━━━━━━━━━━━━━
# セキュリティヘッダー
# ━━━━━━━━━━━━━━━━━━━━
<IfModule mod_headers.c>
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ━━━━━━━━━━━━━━━━━━━━
# Gzip圧縮
# ━━━━━━━━━━━━━━━━━━━━
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json application/xml text/xml
</IfModule>

# ━━━━━━━━━━━━━━━━━━━━
# ブラウザキャッシュ
# ━━━━━━━━━━━━━━━━━━━━
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
